#!/bin/bash
# ============================================
# Opencode 启动器
# 将此文件放到任意项目文件夹中，双击即可
# 从该文件夹启动 opencode
# ============================================

# 获取脚本自身所在的目录并切换到该目录
cd "$(dirname "$0")/../.." || {
  echo "❌ 无法切换到脚本所在目录"
  exit 1
}

echo "📂 项目目录: $(pwd)"
echo "🚀 正在启动 opencode ..."
echo ""

# 启动 opencode（替换当前进程）
exec opencode
